# Keep line endings consistent across Windows / macOS clones.
# Without this, the .sh launcher can land on disk with CRLF after a
# clone on Windows and refuse to run on Mac.

* text=auto eol=lf

# Force LF for shell scripts and Python so they work everywhere.
*.sh    text eol=lf
*.py    text eol=lf

# Force CRLF for Windows batch files so cmd.exe is happy.
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary types — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.mp3   binary
*.wav   binary
*.pdf   binary
*.zip   binary
