    {
      "id": "practice",
      "title": "Checking in",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "Buenas tardes. Tengo una reserva.",
          "en": "Good afternoon. I have a reservation."
        },
        {
          "speaker": "B",
          "es": "¿A qué nombre?",
          "en": "Under what name?"
        },
        {
          "speaker": "A",
          "es": "A nombre de Daniel.",
          "en": "Under the name Daniel."
        },
        {
          "speaker": "B",
          "es": "Perfecto. Su habitación está en el segundo piso.",
          "en": "Perfect. Your room is on the second floor."
        }
      ]
    }
