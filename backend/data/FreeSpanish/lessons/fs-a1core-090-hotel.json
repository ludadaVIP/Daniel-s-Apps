          "es": "Tengo una reserva.",
          "en": "I have a reservation."
        },
        {
          "es": "Quisiera una habitación tranquila.",
          "en": "I would like a quiet room."
        },
        {
          "es": "¿Dónde está el ascensor?",
          "en": "Where is the elevator?"
        },
        {
          "es": "La llave no funciona.",
          "en": "The key does not work."
        },
        {
          "es": "Necesito otra toalla.",
          "en": "I need another towel."
        }
      ]
