  "overview": [
    "Phone Spanish can be short and clear.",
    "Use llamar, mandar, and dejar un mensaje."
  ],
  "sections": [
    {
      "id": "phrases",
      "title": "Phone phrases",
      "kind": "cards",
      "items": [
        {
          "es": "¿Puedo hablar con Ana?",
          "en": "Can I speak with Ana?"
        },
        {
          "es": "No está en casa.",
          "en": "She is not at home."
        },
        {
          "es": "¿Puedo dejar un mensaje?",
          "en": "Can I leave a message?"
        },
        {
          "es": "Te llamo después.",
          "en": "I will call you later."
        },
        {
          "es": "Mándame un mensaje.",
          "en": "Send me a message."
        }
      ]
    },
    {
      "id": "practice",
      "title": "Short call",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "Hola, ¿puedo hablar con Ana?",
          "en": "Hello, can I speak with Ana?"
        },
        {
          "speaker": "B",
          "es": "Lo siento, no está aquí.",
          "en": "Sorry, she is not here."
        },
        {
          "speaker": "A",
          "es": "¿Puedo dejar un mensaje?",
          "en": "Can I leave a message?"
        },
        {
          "speaker": "B",
          "es": "Sí, claro.",
          "en": "Yes, of course."
        }
      ]
    }
  ],
