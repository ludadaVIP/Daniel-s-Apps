      "kind": "cards",
      "items": [
        {
          "es": "Hace frío.",
          "en": "It is cold."
        },
        {
          "es": "Hace calor.",
          "en": "It is hot."
        },
        {
          "es": "Hace buen tiempo.",
          "en": "The weather is good."
        },
        {
          "es": "Hace mal tiempo.",
          "en": "The weather is bad."
        },
        {
          "es": "Está lloviendo.",
          "en": "It is raining."
        },
        {
          "es": "Está nublado.",
          "en": "It is cloudy."
        }
      ]
    },
    {
      "id": "practice",
      "title": "Weather and plans",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "¿Qué tiempo hace hoy?",
          "en": "What is the weather like today?"
        },
        {
          "speaker": "B",
          "es": "Hace frío y está lloviendo.",
          "en": "It is cold and it is raining."
        },
        {
          "speaker": "A",
          "es": "Entonces voy a estudiar en casa.",
          "en": "Then I am going to study at home."
        },
        {
          "speaker": "B",
          "es": "Buena idea.",
          "en": "Good idea."
        }
      ]
