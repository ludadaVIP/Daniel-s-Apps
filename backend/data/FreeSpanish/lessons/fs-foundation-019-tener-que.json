    "Tener que means have to.",
    "The second verb stays in the infinitive."
  ],
  "sections": [
    {
      "id": "patterns",
      "title": "Have to patterns",
      "kind": "cards",
      "items": [
        {
          "es": "Tengo que estudiar.",
          "en": "I have to study."
        },
        {
          "es": "Tengo que trabajar hoy.",
          "en": "I have to work today."
        },
        {
          "es": "Tenemos que salir ahora.",
          "en": "We have to leave now."
        },
        {
          "es": "No tengo que ir mañana.",
          "en": "I do not have to go tomorrow."
        }
      ]
    },
    {
      "id": "practice",
      "title": "A small schedule",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "¿Puedes venir?",
          "en": "Can you come?"
        },
        {
          "speaker": "B",
          "es": "No puedo. Tengo que trabajar.",
          "en": "I cannot. I have to work."
        },
        {
          "speaker": "A",
          "es": "¿Y mañana?",
          "en": "And tomorrow?"
        },
        {
          "speaker": "B",
          "es": "Mañana puedo.",
          "en": "Tomorrow I can."
        }
      ]
    }
