  "overview": [
    "Spanish uses tener for several feelings where English uses be.",
    "Treat them as fixed chunks: tengo frío, tengo sueño."
  ],
  "sections": [
    {
      "id": "chunks",
      "title": "Useful tener chunks",
      "kind": "cards",
      "items": [
        {
          "es": "Tengo frío.",
          "en": "I am cold."
        },
        {
          "es": "Tengo calor.",
          "en": "I am hot."
        },
        {
          "es": "Tengo sueño.",
          "en": "I am sleepy."
        },
        {
          "es": "Tengo miedo.",
          "en": "I am afraid."
        },
        {
          "es": "Tengo razón.",
          "en": "I am right."
        },
        {
          "es": "Tengo prisa.",
          "en": "I am in a hurry."
        }
      ]
    },
    {
      "id": "practice",
      "title": "A tired evening",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "¿Quieres caminar?",
          "en": "Do you want to walk?"
        },
        {
          "speaker": "B",
          "es": "No, tengo frío y tengo sueño.",
          "en": "No, I am cold and I am sleepy."
        },
        {
          "speaker": "A",
          "es": "¿Tienes hambre?",
          "en": "Are you hungry?"
        },
        {
          "speaker": "B",
          "es": "Sí, tengo mucha hambre.",
          "en": "Yes, I am very hungry."
        }
      ]
    }
