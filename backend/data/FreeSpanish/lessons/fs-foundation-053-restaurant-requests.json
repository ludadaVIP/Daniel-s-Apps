      "kind": "cards",
      "items": [
        {
          "es": "¿Puede traerme agua?",
          "en": "Can you bring me water?"
        },
        {
          "es": "¿Tiene una mesa para dos?",
          "en": "Do you have a table for two?"
        },
        {
          "es": "Sin azúcar, por favor.",
          "en": "Without sugar, please."
        },
        {
          "es": "Con leche, por favor.",
          "en": "With milk, please."
        },
        {
          "es": "La cuenta, por favor.",
          "en": "The bill, please."
        }
      ]
    },
    {
      "id": "practice",
      "title": "Dinner request",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "Buenas noches. ¿Tiene una mesa para dos?",
          "en": "Good evening. Do you have a table for two?"
        },
        {
          "speaker": "B",
          "es": "Sí, claro. Por aquí.",
          "en": "Yes, of course. This way."
        },
        {
          "speaker": "A",
          "es": "¿Puede traerme agua, por favor?",
          "en": "Can you bring me water, please?"
        },
        {
          "speaker": "B",
          "es": "Claro, ahora mismo.",
          "en": "Of course, right away."
        }
      ]
    }
