          "es": "Quiero un café, por favor.",
          "en": "I want a coffee, please."
        },
        {
          "es": "Quisiera una mesa para dos.",
          "en": "I would like a table for two."
        },
        {
          "es": "¿Tiene agua?",
          "en": "Do you have water?"
        },
        {
          "es": "La cuenta, por favor.",
          "en": "The bill, please."
        }
