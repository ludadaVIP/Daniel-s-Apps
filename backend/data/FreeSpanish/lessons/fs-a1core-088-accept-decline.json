{
  "id": "fs-a1core-088-accept-decline",
  "levelId": "a1-core",
  "title": "Accept and decline politely",
  "subtitle": "Say yes or no without sounding harsh.",
  "tags": [
    "a1-core",
    "a1",
    "speakable"
  ],
  "overview": [
    "Use gracias to soften both yes and no.",
    "Give one small reason when you decline."
  ],
  "sections": [
    {
      "id": "phrases",
      "title": "Polite answers",
      "kind": "cards",
      "items": [
        {
          "es": "Sí, claro.",
          "en": "Yes, of course."
        },
        {
          "es": "Sí, me encantaría.",
          "en": "Yes, I would love to."
        },
        {
          "es": "Lo siento, no puedo.",
          "en": "Sorry, I cannot."
        },
        {
          "es": "Quizás mañana.",
          "en": "Maybe tomorrow."
        },
        {
          "es": "Gracias por invitarme.",
          "en": "Thanks for inviting me."
        }
      ]
    },
    {
      "id": "practice",
      "title": "Declining kindly",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "¿Quieres venir a cenar?",
          "en": "Do you want to come to dinner?"
        },
        {
          "speaker": "B",
          "es": "Gracias por invitarme, pero no puedo hoy.",
          "en": "Thanks for inviting me, but I cannot today."
        },
        {
          "speaker": "A",
          "es": "No pasa nada. ¿Quizás mañana?",
          "en": "No problem. Maybe tomorrow?"
        },
        {
          "speaker": "B",
          "es": "Sí, mañana puedo.",
          "en": "Yes, tomorrow I can."
        }
      ]
    }
  ],
