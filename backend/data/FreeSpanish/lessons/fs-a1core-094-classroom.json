          "en": "I do not understand this word."
        },
        {
          "es": "¿Puede repetir, por favor?",
          "en": "Can you repeat, please?"
        },
        {
          "es": "¿Cómo se dice esto en español?",
          "en": "How do you say this in Spanish?"
        },
