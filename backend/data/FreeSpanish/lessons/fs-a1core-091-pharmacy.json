      "title": "Pharmacy phrases",
      "kind": "cards",
      "items": [
        {
          "es": "Me duele la cabeza.",
          "en": "My head hurts."
        },
        {
          "es": "Tengo tos.",
          "en": "I have a cough."
        },
        {
          "es": "Tengo fiebre.",
          "en": "I have a fever."
        },
        {
          "es": "Necesito algo para el dolor.",
          "en": "I need something for the pain."
        },
        {
          "es": "¿Cuánto cuesta?",
          "en": "How much does it cost?"
        }
      ]
    },
    {
      "id": "practice",
      "title": "At the pharmacy",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "es": "Hola, tengo tos y me duele la garganta.",
          "en": "Hello, I have a cough and my throat hurts."
        },
        {
          "speaker": "B",
          "es": "¿Tiene fiebre?",
          "en": "Do you have a fever?"
        },
        {
          "speaker": "A",
          "es": "No, no tengo fiebre.",
          "en": "No, I do not have a fever."
        },
        {
          "speaker": "B",
          "es": "Necesita descansar y beber agua.",
          "en": "You need to rest and drink water."
        }
      ]
    }
