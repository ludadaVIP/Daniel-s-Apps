      "note": "先掌握口语最高频问法。",
      "blocks": [
        {
          "id": "pt-question-can",
          "type": "pattern",
          "text": "Vous pouvez ... ?",
          "audioText": "Vous pouvez répéter ?",
          "translation": "您可以……吗？",
          "rule": "礼貌请求常用 vous pouvez。",
          "examples": [
            {
              "text": "Vous pouvez répéter ?",
              "audioText": "Vous pouvez répéter ?",
              "translation": "您可以重复吗？"
            },
            {
              "text": "Vous pouvez parler plus lentement ?",
              "audioText": "Vous pouvez parler plus lentement ?",
              "translation": "您可以说慢一点吗？"
            },
            {
              "text": "Vous pouvez m’aider ?",
              "audioText": "Vous pouvez m’aider ?",
              "translation": "您可以帮我吗？"
            },
            {
              "text": "Vous pouvez attendre ici ?",
              "audioText": "Vous pouvez attendre ici ?",
              "translation": "您可以在这里等吗？"
            }
          ]
        },
        {
          "id": "pt-question-want",
          "type": "pattern",
          "text": "Tu veux / Vous voulez ... ?",
          "audioText": "Vous voulez un café ?",
          "translation": "你想 / 您想……吗？",
          "rule": "点餐、邀请、确认都高频。",
          "examples": [
            {
              "text": "Tu veux venir ?",
              "audioText": "Tu veux venir ?",
              "translation": "你想来吗？"
            },
            {
              "text": "Vous voulez un café ?",
              "audioText": "Vous voulez un café ?",
              "translation": "您想要咖啡吗？"
            },
            {
              "text": "Tu veux essayer ?",
              "audioText": "Tu veux essayer ?",
              "translation": "你想试试吗？"
            },
            {
              "text": "Vous voulez regarder ?",
              "audioText": "Vous voulez regarder ?",
              "translation": "您想看看吗？"
            }
          ]
        },
        {
          "id": "pt-question-where",
          "type": "pattern",
          "text": "Où est / Où sont ... ?",
          "audioText": "Où est la gare ?",
          "translation": "在哪里？",
          "rule": "où + être 是找地点最快的句型。",
          "examples": [
            {
              "text": "Où est la gare ?",
              "audioText": "Où est la gare ?",
              "translation": "火车站在哪里？"
            },
            {
              "text": "Où est la clé ?",
              "audioText": "Où est la clé ?",
              "translation": "钥匙在哪里？"
            },
            {
              "text": "Où sont les toilettes ?",
              "audioText": "Où sont les toilettes ?",
              "translation": "洗手间在哪里？"
            },
            {
              "text": "Où est votre bureau ?",
              "audioText": "Où est votre bureau ?",
              "translation": "您的办公室在哪里？"
            }
          ]
        }
      ]
    },
    {
      "id": "present-negative-expanded",
