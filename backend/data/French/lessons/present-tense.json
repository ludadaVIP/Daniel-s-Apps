            {
              "text": "Vous n’êtes pas seul.",
              "audioText": "Vous n’êtes pas seul.",
              "translation": "您不是一个人。"
            }
          ]
        },
        {
          "id": "pt-neg-avoir",
          "type": "pattern",
          "text": "n’ai pas / n’a pas",
          "audioText": "Je n’ai pas le temps.",
          "translation": "没有。",
          "rule": "avoir 前面元音要 n’。",
