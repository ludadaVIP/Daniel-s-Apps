      "note": "把 ne...pas 套到不同高频动词上。",
      "blocks": [
        {
          "id": "pt-neg-etre",
          "type": "pattern",
          "text": "ne suis pas / n’est pas",
          "audioText": "Je ne suis pas prêt.",
          "translation": "不是 / 不在 / 状态不是。",
          "rule": "口语里 ne 常弱化，但先按完整结构学。",
          "examples": [
            {
              "text": "Je ne suis pas prêt.",
              "audioText": "Je ne suis pas prêt.",
              "translation": "我没准备好。"
            },
            {
              "text": "Elle n’est pas ici.",
