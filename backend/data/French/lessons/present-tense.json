              "audioText": "Nous n’avons pas de problème.",
              "translation": "我们没有问题。"
            },
            {
              "text": "Vous n’avez pas besoin de ça.",
              "audioText": "Vous n’avez pas besoin de ça.",
              "translation": "您不需要这个。"
            }
          ]
        },
        {
          "id": "pt-neg-modal",
