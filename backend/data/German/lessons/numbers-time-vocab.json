        {"id": "f-kind", "type": "word", "text": "das Kind", "audioText": "das Kind", "translation": "child / niño/a"},
        {"id": "f-oma", "type": "word", "text": "die Oma / die Großmutter", "audioText": "die Oma, die Großmutter", "translation": "grandma / abuela"},
        {"id": "f-opa", "type": "word", "text": "der Opa / der Großvater", "audioText": "der Opa, der Großvater", "translation": "grandpa / abuelo"}
      ]
