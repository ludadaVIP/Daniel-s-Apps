        {"id": "d-di", "type": "word", "text": "der Dienstag", "audioText": "der Dienstag", "translation": "Tuesday / martes"},
        {"id": "d-mi", "type": "word", "text": "der Mittwoch", "audioText": "der Mittwoch", "translation": "Wednesday / miércoles"},
        {"id": "d-do", "type": "word", "text": "der Donnerstag", "audioText": "der Donnerstag", "translation": "Thursday / jueves"},
        {"id": "d-fr", "type": "word", "text": "der Freitag", "audioText": "der Freitag", "translation": "Friday / viernes"},
        {"id": "d-sa", "type": "word", "text": "der Samstag", "audioText": "der Samstag", "translation": "Saturday / sábado", "hint": "Also 'der Sonnabend' in north Germany."},
        {"id": "d-so", "type": "word", "text": "der Sonntag", "audioText": "der Sonntag", "translation": "Sunday / domingo"},
        {"id": "m-jan", "type": "word", "text": "Januar, Februar, März", "audioText": "Januar, Februar, März", "translation": "January, February, March / enero, febrero, marzo"},
        {"id": "m-apr", "type": "word", "text": "April, Mai, Juni", "audioText": "April, Mai, Juni", "translation": "April, May, June / abril, mayo, junio"},
        {"id": "m-jul", "type": "word", "text": "Juli, August, September", "audioText": "Juli, August, September", "translation": "July, August, September"},
        {"id": "m-okt", "type": "word", "text": "Oktober, November, Dezember", "audioText": "Oktober, November, Dezember", "translation": "October, November, December"},
        {"id": "s-frühling", "type": "word", "text": "der Frühling", "audioText": "der Frühling", "translation": "spring / primavera"},
        {"id": "s-sommer", "type": "word", "text": "der Sommer", "audioText": "der Sommer", "translation": "summer / verano"},
        {"id": "s-herbst", "type": "word", "text": "der Herbst", "audioText": "der Herbst", "translation": "autumn, fall / otoño"},
        {"id": "s-winter", "type": "word", "text": "der Winter", "audioText": "der Winter", "translation": "winter / invierno"}
