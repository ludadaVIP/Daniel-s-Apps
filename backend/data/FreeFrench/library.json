    {
      "id": "there-is-il-y-a",
      "levelId": "foundation",
      "title": "There is / there are: il y a",
      "subtitle": "The beginner structure that unlocks places, objects, and descriptions.",
      "tags": [
        "A1",
        "sentence pattern",
        "il y a"
      ],
      "duolingoBridge": "Useful beside Duolingo sentences about rooms, food, people, city places, and quantities.",
      "overview": [
        "French uses one shape for singular and plural: il y a.",
        "Negation often becomes il n'y a pas de + noun.",
        "Ask with est-ce qu'il y a...? for an easy beginner question."
      ],
      "sections": [
        {
          "id": "patterns",
          "title": "Core patterns",
          "kind": "table",
          "columns": [
            "French",
            "English",
            "Spanish"
          ],
          "rows": [
            [
              "Il y a un livre.",
              "There is a book.",
              "Hay un libro."
            ],
            [
              "Il y a deux cafés.",
              "There are two cafés.",
              "Hay dos cafés."
            ],
            [
              "Il n'y a pas de problème.",
              "There is no problem.",
              "No hay problema."
            ],
            [
              "Est-ce qu'il y a une table ?",
              "Is there a table?",
              "¿Hay una mesa?"
            ],
            [
              "Qu'est-ce qu'il y a ?",
              "What is there? / What is wrong?",
              "¿Qué hay? / ¿Qué pasa?"
            ],
            [
              "Il y avait un train.",
              "There was a train.",
              "Había un tren."
            ],
            [
              "Il y aura une réunion.",
              "There will be a meeting.",
              "Habrá una reunión."
            ]
          ]
        },
        {
          "id": "substitution",
          "title": "Substitution drill",
          "kind": "cards",
          "items": [
            {
