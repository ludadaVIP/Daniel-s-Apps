  "sections": [
    {
      "id": "greeting",
      "title": "Greeting",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "fr": "Bonjour ! Comment ça va ?",
          "en": "Hello! How are you?",
          "es": "¡Hola! ¿Cómo estás?"
        },
        {
          "speaker": "B",
          "fr": "Ça va bien, merci. Et toi ?",
          "en": "I'm well, thanks. And you?",
          "es": "Estoy bien, gracias. ¿Y tú?"
        },
        {
          "speaker": "A",
          "fr": "Très bien. Je m'appelle Daniel.",
          "en": "Very well. My name is Daniel.",
          "es": "Muy bien. Me llamo Daniel."
        },
        {
          "speaker": "B",
          "fr": "Enchanté. Moi, c'est Sophie.",
          "en": "Nice to meet you. I'm Sophie.",
          "es": "Encantada. Yo soy Sophie."
        }
      ]
    },
    {
      "id": "cafe",
      "title": "At a café",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "fr": "Bonjour, je voudrais un café, s'il vous plaît.",
          "en": "Hello, I would like a coffee, please.",
          "es": "Hola, quisiera un café, por favor."
        },
        {
          "speaker": "B",
          "fr": "Bien sûr. Avec du lait ?",
          "en": "Of course. With milk?",
          "es": "Claro. ¿Con leche?"
        },
        {
          "speaker": "A",
          "fr": "Non, merci. Un café noir.",
          "en": "No, thank you. A black coffee.",
          "es": "No, gracias. Un café solo."
        },
        {
          "speaker": "B",
          "fr": "Voilà. Ça fait deux euros.",
          "en": "Here you go. That's two euros.",
          "es": "Aquí tiene. Son dos euros."
        }
      ]
    },
    {
      "id": "asking-place",
      "title": "Asking where something is",
      "kind": "dialogue",
      "lines": [
        {
          "speaker": "A",
          "fr": "Excusez-moi, où est la gare ?",
          "en": "Excuse me, where is the train station?",
          "es": "Disculpe, ¿dónde está la estación?"
        },
        {
          "speaker": "B",
          "fr": "La gare est à gauche, près du café.",
          "en": "The station is on the left, near the café.",
          "es": "La estación está a la izquierda, cerca del café."
        },
        {
          "speaker": "A",
          "fr": "Merci beaucoup.",
          "en": "Thank you very much.",
          "es": "Muchas gracias."
        },
        {
          "speaker": "B",
          "fr": "De rien. Bonne journée !",
          "en": "You're welcome. Have a good day!",
          "es": "De nada. ¡Buen día!"
        }
      ]
    },
    {
      "id": "use-it-now",
      "title": "Use it now",
      "kind": "cards",
      "items": [
        {
          "fr": "Bonjour, je m'appelle Daniel.",
          "en": "Hello, my name is Daniel.",
          "es": "Hola, me llamo Daniel."
        },
        {
          "fr": "Comment ça va aujourd'hui ?",
          "en": "How are you today?",
          "es": "¿Cómo estás hoy?"
        },
        {
          "fr": "Je voudrais un café, s'il vous plaît.",
          "en": "I would like a coffee, please.",
          "es": "Quisiera un café, por favor."
        },
        {
          "fr": "Où est la gare ?",
          "en": "Where is the station?",
          "es": "¿Dónde está la estación?"
        },
        {
          "fr": "Merci beaucoup. Bonne journée !",
          "en": "Thank you very much. Have a good day!",
          "es": "Muchas gracias. ¡Buen día!"
        }
      ]
    }
  ],
