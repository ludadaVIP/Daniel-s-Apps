# =====================================================================
# Daniel's Apps — .gitignore
# Cross-platform (Windows + macOS). If you add tools later, append rules
# at the bottom rather than reshuffling the categories.
# =====================================================================

# ---------- Python -----------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments (any common name)
.venv/
venv/
env/
.env/
ENV/

# ---------- Node / Vite -----------------------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/
.parcel-cache/
.cache/
.vite/

# Build output (Vite writes to frontend/dist by default)
frontend/dist/

# ---------- Local env / secrets ---------------------------------------
.env
.env.*
!.env.example

# ---------- Logs ------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Editors / IDEs --------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
*.swp
*.swo
*~

# ---------- OS junk ---------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ---------- Local app state -------------------------------------------
# Keep shared app code and curriculum JSON in Git, but keep per-device
# learning state local. These files are generated while studying and will
# differ between Mac/Windows machines.
backend/data/**/audio/
backend/data/**/progress/

# Edge-TTS rebuilds audio on demand. If you ever need to commit a specific
# clip deliberately, use `git add -f path/to/file.mp3`.
*.mp3
*.wav

# ---------- Misc ------------------------------------------------------
*.bak
*.tmp
*.temp
.claude/settings.local.json
